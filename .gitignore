# Laravel
.env
.env.*
!.env.example
/vendor
/storage/*.key

# Laravel runtime storage
/storage/app/*
!/storage/app/.gitignore
/storage/app/private/*
!/storage/app/private/.gitignore
/storage/app/public/*
!/storage/app/public/.gitignore
/storage/framework/cache/*
!/storage/framework/cache/.gitignore
/storage/framework/sessions/*
!/storage/framework/sessions/.gitignore
/storage/framework/testing/*
!/storage/framework/testing/.gitignore
/storage/framework/views/*
!/storage/framework/views/.gitignore
/storage/logs/*
!/storage/logs/.gitignore

/bootstrap/cache/*.php

# Base de datos local / producción
/database/database.sqlite
/database/*.sqlite

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Vite dev
/public/hot

# Storage symlink
/public/storage

# Astro separado, si existe
/astro-catalog/node_modules
/astro-catalog/.env
/astro-catalog/.env.*

# OJO:
# No ignoramos /public/build porque en Laravel + Vite normalmente debe subir si compilas local.
# No ignoramos /astro-catalog/dist si decides subir el build de Astro por Git.
# Si prefieres compilar Astro en hosting, ahí sí lo ignoramos después.

# OS / Editor
.DS_Store
Thumbs.db
.vscode/
.idea/

# Logs y backups
*.log
*.zip
*_backup*
